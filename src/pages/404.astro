---
import Layout from "../layouts/Layout.astro";
---
<Layout title="404 — Page not found — HostFleet" description="The page you requested does not exist on hostfleet.net.">
  <main class="max-w-2xl mx-auto px-6 py-24 text-center">
    <div class="font-mono text-xs uppercase tracking-widest text-[var(--color-accent)] mb-4">404</div>
    <h1 class="text-5xl font-semibold tracking-tight leading-[1.1]">Page not found</h1>
    <p class="mt-6 text-lg text-[var(--color-text-dim)]">The URL you followed does not exist on hostfleet.net. It may have been deleted, moved, or never existed.</p>
    <div class="mt-10 flex flex-wrap gap-3 justify-center">
      <a href="/" class="px-4 py-2 rounded bg-[var(--color-accent)] text-black font-mono text-sm">Home</a>
      <a href="/ai-hosting/" class="px-4 py-2 rounded border border-[var(--color-border)] font-mono text-sm">AI Hosting</a>
      <a href="/edge/" class="px-4 py-2 rounded border border-[var(--color-border)] font-mono text-sm">Edge</a>
      <a href="/deploy-ai-apps/" class="px-4 py-2 rounded border border-[var(--color-border)] font-mono text-sm">Deploy</a>
    </div>
  </main>
</Layout>
