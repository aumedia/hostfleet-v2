---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
let posts = [];
try { posts = await getCollection("posts"); } catch {}
posts = posts.filter(p => !p.data.draft && p.data.category === 'deploy-ai-apps');
posts.sort((a,b) => +new Date(b.data.pubDate) - +new Date(a.data.pubDate));
---
<Layout title="Deploy AI-generated sites — HostFleet" description="Where Lovable, Bolt, and v0 outputs actually land in production.">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-24">
    <div class="font-mono text-xs uppercase tracking-widest text-[var(--color-accent)]">deploy-ai-apps</div>
    <h1 class="text-4xl font-semibold tracking-tight mt-2">Deploy AI-generated sites</h1>
    <p class="mt-3 text-[var(--color-text-dim)] text-lg">Where Lovable, Bolt, and v0 outputs actually land in production.</p>
    <ul class="mt-10 divide-y divide-[var(--color-border)]">
      {posts.map(p => (
        <li class="py-5">
          <a href={`/${p.id}/`} class="block hover:text-[var(--color-accent)]">
            <div class="font-semibold text-lg">{p.data.title}</div>
            <div class="text-sm text-[var(--color-text-dim)] mt-1">{p.data.description}</div>
            <div class="font-mono text-xs text-[var(--color-text-dim)] mt-2">{new Date(p.data.pubDate).toISOString().slice(0,10)}</div>
          </a>
        </li>
      ))}
      {posts.length === 0 && (<li class="py-5 text-[var(--color-text-dim)] font-mono text-sm">No posts yet — first benchmarks publishing this week.</li>)}
    </ul>
  </section>
</Layout>
