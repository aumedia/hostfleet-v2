---
import "../styles/global.css";
const { title = "HostFleet — Ship AI Apps. Everywhere.", description = "Independent benchmarks and reviews of AI infrastructure. Where to host inference, edge apps, and AI-generated sites in 2026.", canonical, image } = Astro.props;
const url = canonical ?? new URL(Astro.url.pathname, Astro.site ?? "https://hostfleet.net").toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image ?? new URL("/og-default.png", Astro.site).toString()}>
  <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://rsms.me" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <!-- GA4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-W2SWWQV9BJ"></script>
    <script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag("js",new Date());gtag("config","G-W2SWWQV9BJ",{anonymize_ip:true});</script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-[var(--color-border)] bg-[var(--color-bg)]/80 backdrop-blur sticky top-0 z-10">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-mono text-sm">
          <span class="text-[var(--color-accent)]">▲</span>
          <span class="font-semibold tracking-tight">hostfleet</span>
          <span class="text-[var(--color-text-dim)]">/v2</span>
        </a>
        <nav class="flex items-center gap-6 text-sm font-mono">
          <a href="/ai-hosting/">AI Hosting</a>
          <a href="/edge/">Edge</a>
          <a href="/deploy-ai-apps/">Deploy</a>
          <a href="/about/">About</a>
        </nav>
      </div>
    </header>
    <main class="flex-1"><slot /></main>
    <footer class="border-t border-[var(--color-border)] mt-24">
      <div class="max-w-5xl mx-auto px-6 py-10 text-sm text-[var(--color-text-dim)] flex flex-col md:flex-row md:justify-between gap-4">
        <div>
          <div class="font-mono text-[var(--color-text)]">hostfleet.net</div>
          <div>Independent benchmarks for AI deployment infrastructure.</div>
        </div>
        <div class="font-mono">
          <div>Editor: <span class="text-[var(--color-text)]">Alex Harmon</span> — Senior Infrastructure Analyst</div>
          <div>Some links may be affiliate. Methodology is open.</div>
        </div>
      </div>
    </footer>
  </body>
</html>
